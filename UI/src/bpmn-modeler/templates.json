[
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",

    "name": "Temporal Activity Task",
    "id": "io.temporal.activity",
    "version": 1,

    "description": "Execute Temporal activity worker",

    "documentationRef": "https://temporal.io/",

    "keywords": [
      "temporal",
      "activity",
      "worker"
    ],

    "category": {
      "id": "temporal",
      "name": "Temporal"
    },

    "icon": {
      "contents": "data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDov..."
    },

    "engines": {
      "camunda": "^8.0.0"
    },

    "appliesTo": [
      "bpmn:ServiceTask"
    ],

    "elementType": {
      "value": "bpmn:ServiceTask"
    },

    "groups": [
      {
        "id": "general",
        "label": "General"
      },
      {
        "id": "timeouts",
        "label": "Timeouts"
      },
      {
        "id": "io",
        "label": "Input / Output"
      }
    ],

    "properties": [

      {
        "group": "general",
        "label": "Task Type",
        "type": "Hidden",
        "value": "temporal-activity",
        "binding": {
          "type": "zeebe:taskDefinition:type"
        }
      },

      {
        "group": "general",
        "label": "Activity Name",
        "type": "String",

        "feel": "optional",

        "description": "Temporal activity type",

        "binding": {
          "type": "zeebe:taskHeader",
          "key": "activityType"
        },

        "constraints": {
          "notEmpty": true
        }
      },

      {
        "group": "general",
        "label": "Task Queue",
        "type": "String",

        "binding": {
          "type": "zeebe:taskHeader",
          "key": "taskQueue"
        }
      },

      {
        "group": "general",
        "label": "Retries",
        "type": "String",

        "value": "3",

        "binding": {
          "type": "zeebe:taskDefinition:retries"
        }
      },

      {
        "group": "general",
        "label": "Retry Policy",
        "type": "Dropdown",

        "choices": [
          {
            "name": "None",
            "value": "none"
          },
          {
            "name": "Linear",
            "value": "linear"
          },
          {
            "name": "Exponential",
            "value": "exponential"
          }
        ],

        "binding": {
          "type": "zeebe:taskHeader",
          "key": "retryPolicy"
        }
      },

      {
        "group": "timeouts",
        "label": "Start To Close Timeout",
        "type": "String",

        "binding": {
          "type": "zeebe:taskHeader",
          "key": "startToCloseTimeout"
        }
      },

      {
        "group": "timeouts",
        "label": "Heartbeat Timeout",
        "type": "String",

        "binding": {
          "type": "zeebe:taskHeader",
          "key": "heartbeatTimeout"
        }
      },

      {
        "group": "io",
        "label": "Input Variables",
        "type": "Text",

        "feel": "required",

        "binding": {
          "type": "zeebe:input",
          "name": "payload"
        }
      },

      {
        "group": "io",
        "label": "Result Variable",
        "type": "String",

        "binding": {
          "type": "zeebe:output",
          "source": "=result",
          "target": "activityResult"
        }
      }
    ]
  }
]