[
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "name": "Department Stage Task",
    "id": "workflow-engine.dept-stage-task",
    "version": 1,
    "description": "A Prep, Review, or Approve stage task for a workflow engine department.",
    "appliesTo": ["bpmn:UserTask"],
    "groups": [
      {
        "id": "department",
        "label": "Department"
      },
      {
        "id": "stage",
        "label": "Stage"
      }
    ],
    "properties": [
      {
        "group": "department",
        "label": "Department",
        "description": "Which department this task belongs to",
        "type": "Dropdown",
        "value": "design",
        "binding": {
          "type": "zeebe:property",
          "name": "dept_id"
        },
        "choices": [
          { "name": "Design / Engineering", "value": "design" },
          { "name": "Contract Management",  "value": "contracts" },
          { "name": "Procurement",          "value": "procurement" },
          { "name": "Planning",             "value": "planning" },
          { "name": "Logistics",            "value": "logistics" },
          { "name": "HSE",                  "value": "hse" },
          { "name": "Construction",         "value": "construction" },
          { "name": "QA / QC",              "value": "qa" },
          { "name": "Commissioning",        "value": "commissioning" }
        ],
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "group": "stage",
        "label": "Stage Type",
        "description": "The stage within this department",
        "type": "Dropdown",
        "value": "prep",
        "binding": {
          "type": "zeebe:property",
          "name": "stage_type"
        },
        "choices": [
          { "name": "Prep",    "value": "prep" },
          { "name": "Review",  "value": "review" },
          { "name": "Approve", "value": "approve" }
        ],
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "group": "stage",
        "label": "Assignee Role",
        "description": "The IAM role responsible for this stage",
        "type": "Dropdown",
        "value": "preparer",
        "binding": {
          "type": "zeebe:property",
          "name": "role"
        },
        "choices": [
          { "name": "Preparer",  "value": "preparer" },
          { "name": "Reviewer",  "value": "reviewer" },
          { "name": "Approver",  "value": "approver" }
        ]
      },
      {
        "group": "stage",
        "label": "Requires Comment Before Approval",
        "description": "A comment must be added before this stage can be approved",
        "type": "Checkbox",
        "value": true,
        "binding": {
          "type": "zeebe:property",
          "name": "requires_comment"
        }
      }
    ]
  }
]